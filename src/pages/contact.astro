---
import ContactWhatsAppCTA from '../components/ContactWhatsAppCTA.astro';
import MainLayout from '../layouts/MainLayout.astro';
import { siteConfig } from '../config/site';

const whatsappLink = `https://wa.me/${siteConfig.phoneE164}`;
---

<MainLayout
  title="Contact"
  description="Contact Novalink for practical SME support across websites, workflows, automation, and commerce implementation."
>
  <section class="container-shell pt-14">
    <h1 class="text-3xl font-semibold text-slate-900 sm:text-4xl">Get in touch</h1>
    <p class="mt-4 max-w-3xl text-base text-slate-600">
      Send us your business details and ideas and we'll come back to you with clear next steps.
    </p>
    <div class="mt-6 flex flex-col gap-3 sm:flex-row">
      <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="btn-primary text-center">Chat on WhatsApp</a>
      <a href={`mailto:${siteConfig.email}`} class="btn-secondary text-center">Email Novalink</a>
    </div>
  </section>

  <!-- <section class="container-shell pt-12">
    <div class="panel p-6 sm:p-8">
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">What to Include in Your First Message</h2>
      <ol class="mt-4 space-y-2 text-sm text-slate-600">
        <li>1. Business type and market</li>
        <li>2. Current setup (website, tools, or process)</li>
        <li>3. Main problem to solve</li>
        <li>4. Timeline and urgency</li>
        <li>5. Desired outcome</li>
      </ol>
    </div>
  </section> -->

  <section class="container-shell pt-12">
    <div class="panel p-6 sm:p-8">
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">Contact Details</h2>
      <div class="mt-4 space-y-4 text-sm text-slate-700">
        <p>
          <span class="block text-xs font-semibold uppercase tracking-wide text-brand-700">WhatsApp</span>
          <a
            class="mt-1 inline-block font-medium text-slate-900 hover:text-brand-800"
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
          >
            {siteConfig.phoneDisplay}
          </a>
        </p>
        <p>
          <span class="block text-xs font-semibold uppercase tracking-wide text-brand-700">Email</span>
          <a class="mt-1 inline-block font-medium text-slate-900 hover:text-brand-800" href={`mailto:${siteConfig.email}`}>
            {siteConfig.email}
          </a>
        </p>
        <p>
          <span class="block text-xs font-semibold uppercase tracking-wide text-brand-700">Location</span>
          <span class="mt-1 inline-block font-medium text-slate-900">{siteConfig.city}</span>
        </p>
      </div>
    </div>
  </section>

  <section class="container-shell pt-12">
    <div class="panel p-6 sm:p-8">
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">Good-Fit Enquiries</h2>
      <p class="mt-3 text-sm text-slate-600">
        Website or landing page improvements, workflow automation, system integration, commerce/payment setup support, and search/acquisition support tied to practical execution.
      </p>
    </div>
  </section>

  <section class="container-shell pt-12">
    <div class="panel p-6 sm:p-8">
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">Discuss Your Next Step</h2>
      <p class="mt-3 max-w-3xl text-sm text-slate-600">
        Send your brief and timeline. We will respond with a scoped first step.
      </p>
    </div>
  </section>

  <ContactWhatsAppCTA
    heading="Send Your Brief"
    description="Send your business type, current setup, and priority. We will reply with practical next steps."
  />
</MainLayout>
