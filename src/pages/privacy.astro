---
import MainLayout from '../layouts/MainLayout.astro';
import { siteConfig } from '../config/site';
---

<MainLayout title="Privacy Policy" description="Novalink Technologies privacy policy placeholder.">
  <section class="container-shell pt-14">
    <h1 class="text-3xl font-semibold text-slate-900 sm:text-4xl">Privacy Policy</h1>
    <p class="mt-4 max-w-3xl text-sm text-slate-600">
      This is a placeholder privacy page for the initial launch. Replace with your approved legal policy before production go-live.
    </p>
  </section>

  <section class="container-shell pt-12">
    <div class="panel space-y-4 p-6 text-sm text-slate-600">
      <p>We collect only information necessary to respond to inquiries and deliver requested services.</p>
      <p>Personal data handling, retention periods, and third-party processors should be documented in the final policy copy.</p>
      <p>
        For now, direct privacy questions to
        <a class="font-medium text-brand-800" href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>.
      </p>
    </div>
  </section>
</MainLayout>
