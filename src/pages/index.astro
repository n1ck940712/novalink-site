---
import CTASection from '../components/CTASection.astro';
import ContactWhatsAppCTA from '../components/ContactWhatsAppCTA.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import HeroSection from '../components/HeroSection.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import TrustSection from '../components/TrustSection.astro';
import { siteConfig } from '../config/site';
import { coreServices, homeFAQs, homeProofMetrics } from '../content/site-data';
import MainLayout from '../layouts/MainLayout.astro';

const whatsappLink = `https://wa.me/${siteConfig.phoneE164}`;
---

<MainLayout>
  <HeroSection
    eyebrow="SME Digital Solutions Partner"
    title="Practical digital execution for SMEs"
    description="Novalink Technologies helps businesses improve digital presence, conversion flow, and day-to-day execution across websites, commerce/payment implementation, search, and selected growth systems."
    primaryAction={{ label: 'Chat on WhatsApp', href: whatsappLink }}
    secondaryAction={{ label: 'View Solutions', href: '/services' }}
  />

  <ServicesGrid
    heading="Core Solutions"
    intro="Start with one scoped area or combine support tracks based on current business priorities."
    items={coreServices}
  />

  <section class="container-shell pt-12">
    <div class="panel p-6 sm:p-8">
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">Commerce & Payment Enablement</h2>
      <p class="mt-3 max-w-3xl text-base text-slate-600">
        Payment and checkout support is part of Novalink's practical execution scope, including e-commerce flow setup and implementation coordination.
      </p>
      <ul class="mt-4 space-y-2 text-sm text-slate-600">
        <li>Checkout flow improvements</li>
        <li>Payment integration guidance</li>
        <li>Merchant onboarding support paths, including Atome</li>
      </ul>
    </div>
  </section>

  <TrustSection
    heading="Why Teams Work With Novalink"
    intro="Practical collaboration, clear scope, and delivery support built for SME teams."
    metrics={homeProofMetrics}
  />

  <CTASection
    title="Need the Atome onboarding route?"
    description="Use the dedicated Atome page for campaign-specific positioning while keeping Novalink's broader SME execution scope clear."
    primaryLabel="Open Atome Page"
    primaryHref="/atome"
    secondaryLabel="General Contact"
    secondaryHref="/contact"
  />

  <FAQAccordion items={homeFAQs} />

  <ContactWhatsAppCTA />
</MainLayout>
