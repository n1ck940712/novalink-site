---
import CTASection from '../components/CTASection.astro';
import { siteConfig } from '../config/site';
import MainLayout from '../layouts/MainLayout.astro';

const whatsappLink = `https://wa.me/${siteConfig.phoneE164}`;
---

<MainLayout
  title="About"
  description="Novalink is an execution-focused digital partner for SMEs, delivering practical systems across websites, workflows, and implementation support."
>
  <section class="container-shell pt-14">
    <h1 class="text-3xl font-semibold text-slate-900 sm:text-4xl">About Novalink Technologies</h1>
    <p class="mt-4 max-w-3xl text-base text-slate-600">
      Novalink is an execution-focused digital partner for SMEs. We build and improve practical systems that help teams run better and convert better.
    </p>
  </section>

  <section class="container-shell pt-12">
    <div class="panel p-6 sm:p-8">
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">How We Work</h2>
      <p class="mt-3 max-w-3xl text-base text-slate-600">
        We define the immediate business constraint, scope a practical first phase, implement with clear ownership, and refine based on what actually improves operations or conversion.
      </p>
      <!-- <ol class="mt-4 space-y-2 text-sm text-slate-600">
        <li>1. Define the main execution constraint and immediate goal.</li>
        <li>2. Scope a practical first phase with clear ownership.</li>
        <li>3. Implement and monitor what changes in operations or conversion flow.</li>
        <li>4. Set clear next steps only after the first scope is working.</li>
      </ol> -->
    </div>
  </section>

  <section class="container-shell pt-12">
    <div class="panel p-6 sm:p-8">
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">What We Help Solve</h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-600">
        Conversion flow issues, slow manual workflows, disconnected tools, underperforming landing pages, and commerce/payment setup friction.
      </p>
      <ul class="mt-4 space-y-2 text-sm text-slate-600">
        <li>Broken or unclear conversion paths from traffic to lead or sale</li>
        <li>Manual workflows slowing daily operations and team handoffs</li>
        <li>Integration and setup gaps across website, CRM, and payment flows</li>
        <li>Execution bottlenecks where strategy exists but implementation stalls</li>
      </ul>
    </div>
  </section>

  <section class="container-shell pt-12">
    <div class="panel p-6 sm:p-8">
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">Best-Fit Businesses</h2>
      <p class="mt-3 max-w-3xl text-base text-slate-600">
        SMEs that want practical implementation support, clear next steps, and operator-level follow-through.
      </p>
      <p class="mt-3 max-w-3xl text-sm text-slate-600">
        The work fits teams that need useful digital systems working in real operating conditions, not presentation-only output.
      </p>
    </div>
  </section>

  <CTASection
    title="Discuss your current priority"
    description="Send your current priority and timeline on WhatsApp. We will propose a practical first step."
    primaryLabel="Chat on WhatsApp"
    primaryHref={whatsappLink}
    secondaryLabel="Email Novalink"
    secondaryHref={`mailto:${siteConfig.email}`}
  />
</MainLayout>
