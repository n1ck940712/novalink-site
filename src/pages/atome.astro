---
import CTASection from '../components/CTASection.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { siteConfig } from '../config/site';
import MainLayout from '../layouts/MainLayout.astro';
import { atomeBenefits, atomeFAQs } from '../content/site-data';

const whatsappLink = `https://wa.me/${siteConfig.phoneE164}`;
---

<MainLayout
  title="Atome"
  description="Dedicated Atome landing path with Novalink positioned as the supporting onboarding and implementation operator."
>
  <!-- TODO(BM-first copy): Replace hero headline, offer explanation, and CTA microcopy with approved BM-first campaign copy. -->
  <section class="container-shell pt-14">
    <div class="panel px-6 py-10 sm:px-10 sm:py-14">
      <p class="inline-flex rounded-full bg-brand-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-brand-800">Atome landing page placeholder</p>
      <h1 class="mt-5 text-3xl font-semibold leading-tight text-slate-900 sm:text-4xl">
        Atome offer path with Novalink onboarding support
      </h1>
      <p class="mt-4 max-w-3xl text-base text-slate-600">
        This route is intentionally campaign-focused. Keep Atome as the primary offer focus while positioning Novalink as the supporting operator for onboarding coordination and merchant-side implementation support.
      </p>
    </div>
  </section>

  <section class="container-shell pt-12">
    <div class="panel p-6 sm:p-8">
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">Onboarding Support Explanation</h2>
      <p class="mt-3 max-w-3xl text-sm text-slate-600">
        Use this block to explain the merchant journey clearly without implying Novalink is Atome internal staff.
      </p>
      <ol class="mt-4 space-y-2 text-sm text-slate-600">
        <li>1. Merchant indicates interest through campaign CTA.</li>
        <li>2. Novalink supports onboarding coordination and requirement collection.</li>
        <li>3. Merchant receives structured follow-up through activation and launch readiness.</li>
      </ol>
      <!-- TODO(BM-first copy): Localize onboarding-step labels and merchant objections handling. -->
    </div>
  </section>

  <section class="container-shell pt-12">
    <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">Benefits Section Placeholder</h2>
    <p class="mt-3 max-w-3xl text-base text-slate-600">
      Keep this area concise and outcome-oriented so campaign copy can be swapped quickly.
    </p>
    <div class="mt-7 grid gap-5 md:grid-cols-3">
      {atomeBenefits.map((benefit) => (
        <article class="panel p-6">
          <h3 class="text-lg font-semibold text-slate-900">{benefit.title}</h3>
          <p class="mt-3 text-sm text-slate-600">{benefit.detail}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container-shell pt-12">
    <div class="panel border-dashed p-6">
      <h2 class="text-xl font-semibold text-slate-900">Offer & Proof Placeholder</h2>
      <p class="mt-3 text-sm text-slate-600">
        Insert campaign-specific offer details, eligibility notes, and proof assets here.
      </p>
      <ul class="mt-4 space-y-2 text-sm text-slate-600">
        <li>Offer summary placeholder</li>
        <li>Eligibility criteria placeholder</li>
        <li>Proof asset placeholder (logos/testimonials/results pending approval)</li>
      </ul>
      <!-- TODO(BM-first copy): Add localized headline, objections bullets, and offer terms language. -->
    </div>
  </section>

  <FAQAccordion
    heading="Atome Landing FAQs"
    intro="Starter FAQ structure for the dedicated Atome route. Replace with campaign-validated questions later."
    items={atomeFAQs}
  />

  <CTASection
    title="Activate this Atome path"
    description="When campaign details are finalized, replace placeholders and route conversion tracking to the approved endpoint."
    primaryLabel="Chat on WhatsApp"
    primaryHref={whatsappLink}
    secondaryLabel="General Contact"
    secondaryHref="/contact"
  />
</MainLayout>
