---
import CTASection from '../components/CTASection.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { siteConfig } from '../config/site';
import MainLayout from '../layouts/MainLayout.astro';
import { atomeBenefits, atomeFAQs } from '../content/site-data';

const whatsappLink = `https://wa.me/${siteConfig.phoneE164}`;
---

<MainLayout
  title="Atome"
  description="Atome merchant onboarding support with practical implementation coordination from Novalink."
>
  <section class="container-shell pt-14">
    <div class="panel px-6 py-10 sm:px-10 sm:py-14">
      <h1 class="mt-5 text-3xl font-semibold leading-tight text-slate-900 sm:text-4xl">
        Atome merchant onboarding support, with practical implementation help
      </h1>
      <p class="mt-4 max-w-3xl text-base text-slate-600">
        Novalink supports merchants through onboarding coordination, setup readiness, and follow-through so activation is clear and operationally manageable.
      </p>
    </div>
  </section>

  <section class="container-shell pt-12">
    <div class="panel p-6 sm:p-8">
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">Merchant Value</h2>
      <p class="mt-3 max-w-3xl text-base text-slate-600">
        If you want to offer Atome and need a practical path from interest to readiness, we help structure the process.
      </p>
    </div>
  </section>

  <section class="container-shell pt-12">
    <div class="panel p-6 sm:p-8">
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">How Support Works</h2>
      <ol class="mt-4 space-y-2 text-sm text-slate-600">
        <li>1. Share your business details and current setup.</li>
        <li>2. We guide requirement collection and onboarding coordination.</li>
        <li>3. We support implementation readiness and handoff clarity.</li>
      </ol>
    </div>
  </section>

  <section class="container-shell pt-12">
    <div class="panel p-6 sm:p-8">
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">What Novalink Supports</h2>
      <p class="mt-3 max-w-3xl text-base text-slate-600">
        Novalink is an independent implementation support partner, not Atome internal staff.
      </p>
      <div class="mt-7 grid gap-5 md:grid-cols-3">
        {atomeBenefits.map((benefit) => (
          <article class="panel p-6">
            <h3 class="text-lg font-semibold text-slate-900">{benefit.title}</h3>
            <p class="mt-3 text-sm text-slate-600">{benefit.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <FAQAccordion
    heading="Atome FAQs"
    intro="Practical answers for merchants evaluating or starting Atome setup support."
    items={atomeFAQs}
  />

  <CTASection
    title="Chat on WhatsApp to start merchant onboarding support"
    description="Share your current status and setup. We will respond with practical next steps."
    primaryLabel="Chat on WhatsApp to start merchant onboarding support"
    primaryHref={whatsappLink}
  />
</MainLayout>
