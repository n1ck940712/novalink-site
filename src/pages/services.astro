---
import CTASection from '../components/CTASection.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import { siteConfig } from '../config/site';
import { coreServices } from '../content/site-data';
import MainLayout from '../layouts/MainLayout.astro';

const whatsappLink = `https://wa.me/${siteConfig.phoneE164}`;
---

<MainLayout
  title="Solutions"
  description="Practical SME solutions across growth systems, websites, commerce/payment enablement, and search/acquisition support."
>
  <section class="container-shell pt-14">
    <h1 class="text-3xl font-semibold text-slate-900 sm:text-4xl">Solutions</h1>
    <p class="mt-4 max-w-3xl text-base text-slate-600">
      Novalink helps SMEs execute better through practical digital systems. Our work is structured around four pillars: Growth Systems &amp; Automation, Websites &amp; Landing Pages, Commerce / Payment Enablement, and Search / Acquisition Support.
    </p>
    <p class="mt-3 max-w-3xl text-sm text-slate-600">
      Each pillar can start as a focused scope and expand only when priorities and ownership are clear.
    </p>
  </section>

  <ServicesGrid
    heading="Four Service Pillars"
    intro="Each pillar defines what it is, the problems it solves, and a realistic starting scope."
    items={coreServices}
  />

  <section class="container-shell pt-12">
    <div class="panel p-6 sm:p-8">
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">How Projects Usually Start</h2>
      <ol class="mt-4 space-y-2 text-sm text-slate-600">
        <li>1. Define business priority and current execution constraint.</li>
        <li>2. Scope a practical first phase, usually 30 to 90 days.</li>
        <li>3. Implement, review outcomes, and confirm next-step scope.</li>
      </ol>
    </div>
  </section>

  <CTASection
    title="Get a Practical First Scope"
    description="Share your current priority and timeline. We will suggest a practical first scope."
    primaryLabel="Chat on WhatsApp"
    primaryHref={whatsappLink}
    secondaryLabel="Email Novalink"
    secondaryHref={`mailto:${siteConfig.email}`}
  />
</MainLayout>
