---
import { siteConfig } from '../config/site';

interface Props {
  heading?: string;
  description?: string;
}

const {
  heading = 'Talk to Novalink',
  description = 'Share your current growth priorities and we will propose a practical next step.',
} = Astro.props;

const whatsappLink = `https://wa.me/${siteConfig.phoneE164}`;
---

<section class="container-shell pt-12" id="contact-cta">
  <div class="panel px-6 py-8 sm:px-8">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <div class="space-y-2">
        <h2 class="text-2xl font-semibold text-slate-900">{heading}</h2>
        <p class="max-w-2xl text-sm text-slate-600">{description}</p>
      </div>
      <div class="flex flex-col gap-3 sm:flex-row">
        <a class="btn-primary text-center" href={whatsappLink} rel="noopener noreferrer" target="_blank">
          WhatsApp Us
        </a>
        <a class="btn-secondary text-center" href={`mailto:${siteConfig.email}`}>
          Email Us
        </a>
      </div>
    </div>
  </div>
</section>
