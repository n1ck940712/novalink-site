---
import { secondaryNavigationLinks } from '../content/site-data';
import { siteConfig, socialLinks } from '../config/site';

const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-white">
  <div class="container-shell grid gap-8 py-12 md:grid-cols-[1.3fr_1fr_1fr]">
    <div class="space-y-3">
      <p class="text-lg font-semibold text-slate-900">{siteConfig.legalName}</p>
      <p class="max-w-md text-sm text-slate-600">
        Novalink helps SMEs improve conversion, operations, and execution through websites, automation, and practical digital systems.
      </p>
    </div>

    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-slate-800">Explore</p>
      <ul class="mt-3 space-y-2 text-sm text-slate-600">
        {secondaryNavigationLinks.map((item) => (
          <li><a class="hover:text-slate-900" href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-slate-800">Contact</p>
      <ul class="mt-3 space-y-2 text-sm text-slate-600">
        <li><a class="hover:text-slate-900" href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>
        <li><a class="hover:text-slate-900" href={`https://wa.me/${siteConfig.phoneE164}`}>{siteConfig.phoneDisplay}</a></li>
        <li>{siteConfig.city}</li>
        <li>
          <a class="hover:text-slate-900" href={socialLinks.linkedin} rel="noopener noreferrer" target="_blank">LinkedIn</a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-slate-200 py-4">
    <div class="container-shell flex flex-col gap-2 text-xs text-slate-500 sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} {siteConfig.name}. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a href="/privacy" class="hover:text-slate-800">Privacy</a>
        <a href="/terms" class="hover:text-slate-800">Terms</a>
      </div>
    </div>
  </div>
</footer>
