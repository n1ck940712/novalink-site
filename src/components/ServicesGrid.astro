---
import type { ServiceItem } from '../content/site-data';

interface Props {
  heading?: string;
  intro?: string;
  items: ServiceItem[];
}

const {
  heading = 'Services',
  intro = 'Modular support that can start small and expand as your priorities evolve.',
  items,
} = Astro.props;
---

<section class="container-shell pt-12" id="services-grid">
  <div class="space-y-4">
    <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">{heading}</h2>
    <p class="max-w-3xl text-base text-slate-600">{intro}</p>
  </div>

  <div class="mt-8 grid gap-5 md:grid-cols-2">
    {items.map((item) => (
      <article class="panel h-full p-6">
        <h3 class="text-lg font-semibold text-slate-900">{item.title}</h3>
        <p class="mt-3 text-sm text-slate-700">{item.summary}</p>
        <ul class="mt-4 space-y-2 text-sm text-slate-600">
          {item.bullets.map((bullet) => (
            <li class="flex items-start gap-2">
              <span class="mt-[0.375rem] inline-block h-1.5 w-1.5 rounded-full bg-brand-500"></span>
              <span>{bullet}</span>
            </li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</section>
