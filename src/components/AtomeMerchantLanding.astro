const t = content[language];
const pageLang = language === 'bm' ? 'ms' : 'en';
---

<AtomeLandingLayout
  title={t.metaTitle}
  description={t.metaDescription}
  lang={pageLang}
  language={language}
  primaryCtaLabel={t.hero.primaryCta}
  primaryCtaHref={whatsappLink}
  noIndex={true}
>
  <section class="container-shell campaign-hero-section">
    <div class="panel overflow-hidden">
      <div class="grid gap-8 px-6 py-8 sm:px-10 sm:py-12 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
        <div>
          <h1 class="text-3xl font-semibold leading-tight text-slate-900 sm:text-4xl">{t.hero.headline}</h1>
          <p class="mt-4 max-w-2xl text-base leading-relaxed text-slate-700">{t.hero.subheadline}</p>
          <p class="mt-4 max-w-2xl text-sm leading-relaxed text-slate-600">{t.hero.supportLine}</p>

          <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a
              href={whatsappLink}
              onclick="return gtag_report_conversion(this.href);"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary text-center"
            >
              {t.hero.primaryCta}
            </a>
            <p class="text-sm text-slate-600">{t.hero.secondaryText}</p>
          </div>
        </div>

        <div class="rounded-3xl border border-slate-200 bg-slate-100 p-2 shadow-[0_20px_40px_-24px_rgba(15,23,42,0.45)]">
          <img
            src="/atome-hero-retail.jpeg"
            alt="Local retail service scene"
            class="h-full w-full rounded-2xl object-cover"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <section id="what-is-atome" class="container-shell campaign-anchor-target campaign-section campaign-section-compact">
    <div class="campaign-explainer rounded-3xl border border-slate-200/80 bg-white/70 px-6 py-6 sm:px-8">
      <div class="max-w-3xl">
        <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">{t.explainer.title}</h2>
        <ul class="mt-4 space-y-2.5 text-sm leading-relaxed text-slate-700">
          {t.explainer.bullets.map((bullet) => (
            <li class="flex gap-3">
              <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-brand-500" aria-hidden="true"></span>
              <span>{bullet}</span>
            </li>
          ))}
        </ul>
        <a
          href={t.explainer.linkHref}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex text-sm font-medium text-slate-600 transition hover:text-slate-900"
        >
          {t.explainer.linkLabel}
        </a>
      </div>
    </div>
  </section>

  <section id="why-merchants" class="container-shell campaign-anchor-target campaign-section">
    <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">{t.why.title}</h2>
    <div class="mt-6 grid gap-4 sm:grid-cols-2">
      {t.why.cards.map((card) => (
        <article class="panel p-5 sm:p-6">
          <h3 class="text-lg font-semibold text-slate-900">{card.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">{card.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="how-it-works" class="container-shell campaign-anchor-target campaign-section">
    <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">{t.howItWorks.title}</h2>
    <div class="mt-6 grid gap-4 md:grid-cols-2">
      {t.howItWorks.steps.map((step, index) => (
        <article class="panel p-5 sm:p-6">
          <div class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-brand-100 text-sm font-semibold text-brand-800">
            {index + 1}
          </div>
          <h3 class="mt-4 text-lg font-semibold text-slate-900">{step.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">{step.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="suitable-for" class="container-shell campaign-anchor-target campaign-section">
    <div class="panel p-6 sm:p-8">
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">{t.suitableFor.title}</h2>
      <ul class="mt-4 space-y-3 text-sm leading-relaxed text-slate-700">
        {t.suitableFor.bullets.map((bullet) => (
          <li class="flex gap-3">
            <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-brand-600" aria-hidden="true"></span>
            <span>{bullet}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section id="prepare-before-enquiry" class="container-shell campaign-anchor-target campaign-section campaign-section-tight">
    <div class="panel campaign-compact-panel">
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">{t.prepare.title}</h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">{t.prepare.intro}</p>
      <ul class="mt-4 space-y-2 text-sm leading-relaxed text-slate-700">
        {t.prepare.bullets.map((bullet) => (
          <li class="flex gap-3">
            <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-brand-600" aria-hidden="true"></span>
            <span>{bullet}</span>
          </li>
        ))}
      </ul>

      <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          href={whatsappLink}
          onclick="return gtag_report_conversion(this.href);"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-center"
        >
          {t.prepare.primaryCta}
        </a>
        <p class="text-sm text-slate-600">{t.prepare.secondaryText}</p>
      </div>
    </div>
  </section>

  <section id="faq" class="container-shell campaign-anchor-target campaign-section campaign-section-separated">
    <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">{t.faq.title}</h2>
    <div class="mt-6 space-y-3">
      {t.faq.mainItems.map((item) => (
        <details class="panel group px-5 py-4">
          <summary class="cursor-pointer list-none text-sm font-semibold text-slate-900 marker:content-none">
            <span class="inline-flex w-full items-start justify-between gap-4">
              <span>{item.question}</span>
              <span class="mt-0.5 text-brand-700 transition group-open:rotate-45">+</span>
            </span>
          </summary>
          <p class="pt-3 text-sm leading-relaxed text-slate-600">{item.answer}</p>
        </details>
      ))}
    </div>

    <!-- <p class="mt-6 max-w-3xl text-sm leading-relaxed text-slate-600">{t.faq.supportLine}</p> -->

    <details class="campaign-faq-secondary mt-6 group rounded-3xl border border-slate-200 bg-slate-50/85 p-5 sm:p-6">
      <summary class="cursor-pointer list-none text-sm font-semibold text-slate-900 marker:content-none">
        <span class="inline-flex w-full items-center justify-between gap-4">
          <span>{t.faq.moreTitle}</span>
          <span class="text-brand-700 transition group-open:rotate-45">+</span>
        </span>
      </summary>

      <div class="mt-5 space-y-5">
        {t.faq.moreGroups.map((group) => (
          <section class="space-y-3">
            <h3 class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">{group.title}</h3>
            <div class="space-y-2.5">
              {group.items.map((item) => (
                <details class="group rounded-2xl border border-slate-200 bg-white px-4 py-3">
                  <summary class="cursor-pointer list-none text-sm font-semibold text-slate-900 marker:content-none">
                    <span class="inline-flex w-full items-start justify-between gap-4">
                      <span>{item.question}</span>
                      <span class="mt-0.5 text-brand-700 transition group-open:rotate-45">+</span>
                    </span>
                  </summary>
                  <p class="pt-3 text-sm leading-relaxed text-slate-600">{item.answer}</p>
                </details>
              ))}
            </div>
          </section>
        ))}

        <p class="text-sm leading-relaxed text-slate-600">{t.faq.supportNote}</p>
      </div>
    </details>
  </section>

  <section class="container-shell campaign-section campaign-section-separated">
    <div class="panel border-slate-300 bg-slate-100 p-6 sm:p-8">
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">{t.note.title}</h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-700">{t.note.body}</p>
      <a
        href={t.note.linkHref}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 inline-flex text-sm font-semibold text-brand-700 transition hover:text-brand-800"
      >
        {t.note.linkLabel}
      </a>
    </div>
  </section>

  <section class="container-shell campaign-section campaign-section-tight">
    <div class="panel campaign-compact-panel">
      <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">{t.finalCta.title}</h2>
      <p class="mt-3 max-w-3xl text-base leading-relaxed text-slate-700">{t.finalCta.body}</p>
      <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          href={whatsappLink}
          onclick="return gtag_report_conversion(this.href);"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-center"
        >
          {t.finalCta.primaryCta}
        </a>
        <p class="text-sm text-slate-600">{t.finalCta.secondaryCta}</p>
      </div>
    </div>
  </section>
</AtomeLandingLayout>

<style>
  .campaign-hero-section {
    padding-top: clamp(2.5rem, 5vw, 3.5rem);
  }

  .campaign-section {
    padding-top: clamp(3.25rem, 6vw, 4.5rem);
  }

  .campaign-section-tight {
    padding-top: clamp(2.5rem, 4.5vw, 3.5rem);
  }

  .campaign-section-compact {
    padding-top: clamp(2rem, 4vw, 2.75rem);
  }

  .campaign-section-separated {
    padding-top: clamp(4rem, 7vw, 5rem);
  }

  .campaign-compact-panel {
    padding: clamp(1.5rem, 3vw, 1.875rem);
  }

  .campaign-explainer {
    box-shadow: 0 10px 24px -22px rgba(15, 23, 42, 0.45);
  }

  .campaign-anchor-target {
    scroll-margin-top: 6.5rem;
  }
</style>
