---
import AtomeLandingLayout from '../layouts/AtomeLandingLayout.astro';
import { siteConfig } from '../config/site';

const whatsappLink = `https://wa.me/${siteConfig.phoneE164}`;
interface Props {
  language?: 'bm' | 'en';
}

const { language = 'bm' } = Astro.props;

const content = {
  bm: {
    metaTitle: 'Atome Merchant Enquiry',
    metaDescription:
      'Halaman enquiry merchant Atome untuk panduan langkah pertama, semakan awal, dan sokongan onboarding oleh Novalink.',
    hero: {
      headline: 'Ingin tawarkan Atome kepada pelanggan anda?',
      subheadline:
        'Bantu bisnes anda tambah pilihan bayaran di checkout dengan panduan enquiry dan onboarding yang lebih jelas.',
      supportLine:
        'Atome ialah pilihan Buy Now Pay Later (BNPL) / bayaran ansuran yang memberi pelanggan lebih fleksibiliti semasa pembelian.',
      primaryCta: 'Buat enquiry merchant',
      secondaryText: 'WhatsApp untuk maklumat lanjut',
    },
    explainer: {
      title: 'Apa itu Atome Buy Now Pay Later?',
      bullets: [
        'Pelanggan boleh membuat pembelian sekarang dan membayar secara ansuran',
        'Atome Malaysia menerangkan pilihan 3 ansuran tanpa faedah',
        'Bagi sesetengah transaksi, pilihan tempoh lebih panjang mungkin tersedia dengan caj yang dipaparkan dalam aplikasi',
        'Bayaran pertama dibuat semasa pembelian, dan bayaran seterusnya dijadualkan dalam aplikasi',
        'Untuk merchant, ini menambah satu lagi pilihan bayaran semasa checkout',
      ],
      linkLabel: 'Rujuk laman rasmi Atome Malaysia',
      linkHref: 'https://www.atome.my/how-it-works',
    },
    why: {
      title: 'Kenapa merchant pertimbangkan Atome',
      cards: [
        {
          title: 'Tawarkan pelanggan pilihan bayaran tambahan',
          body: 'Beri pelanggan satu lagi cara untuk membayar semasa checkout, bergantung pada kesesuaian merchant dan transaksi.',
        },
        {
          title: 'Bantu pelanggan buat keputusan untuk pembelian yang lebih besar',
          body: 'Pilihan bayaran yang lebih fleksibel boleh membantu pelanggan berasa lebih selesa untuk meneruskan pembelian.',
        },
        {
          title: 'Dapatkan panduan yang lebih jelas untuk langkah seterusnya',
          body: 'Merchant boleh menerima panduan yang lebih tersusun tentang proses enquiry dan apa yang perlu disediakan seterusnya.',
        },
        {
          title: 'Sesuai untuk bisnes yang ingin tambah pilihan bayaran',
          body: 'Pilihan tambahan untuk bisnes yang ingin memberikan pelanggan lebih fleksibiliti semasa pembayaran.',
        },
      ],
    },
    howItWorks: {
      title: 'Cara ia berfungsi',
      steps: [
        {
          title: 'Hantar enquiry',
          body: 'Hubungi kami melalui WhatsApp untuk semakan awal.',
        },
        {
          title: 'Kongsi maklumat asas bisnes',
          body: 'Kami akan meminta butiran asas seperti jenis bisnes, lokasi, dan saluran bisnes anda.',
        },
        {
          title: 'Terima panduan langkah seterusnya',
          body: 'Jika bisnes anda sesuai, anda akan menerima panduan tentang apa yang perlu disediakan dan apa yang akan berlaku seterusnya.',
        },
        {
          title: 'Teruskan onboarding jika berkenaan',
          body: 'Kelayakan dan kelulusan tertakluk kepada semakan serta keperluan pihak berkaitan.',
        },
      ],
    },
    suitableFor: {
      title: 'Sesuai untuk bisnes seperti…',
      bullets: [
        'Bisnes yang ingin menawarkan pelanggan pilihan bayaran tambahan',
        'Bisnes yang menguruskan pembelian di mana fleksibiliti bayaran mungkin membantu',
        'Merchant yang bersedia melalui proses semakan dan onboarding',
        'Bisnes yang mahu menambah pilihan bayaran secara lebih tersusun',
      ],
    },
    prepare: {
      title: 'Apa yang perlu disediakan sebelum enquiry',
      intro: 'Untuk memudahkan semakan awal, sediakan maklumat berikut:',
      bullets: ['Nama bisnes', 'Jenis bisnes', 'Lokasi / kawasan', 'Laman web atau halaman media sosial, jika ada'],
      primaryCta: 'Buat enquiry merchant',
      secondaryText: 'WhatsApp untuk semakan awal',
    },
    faq: {
      title: 'Soalan Lazim',
      mainItems: [
        {
          question: 'Adakah Novalink sebahagian daripada Atome?',
          answer:
            'Tidak. Novalink membantu dari segi koordinasi enquiry merchant dan panduan onboarding. Novalink bukan sebahagian daripada pasukan dalaman Atome.',
        },
        {
          question: 'Adakah semua bisnes layak?',
          answer: 'Tidak semestinya. Kesesuaian bergantung kepada semakan dan keperluan pihak berkaitan.',
        },
        {
          question: 'Adakah enquiry ini menjamin kelulusan?',
          answer: 'Tidak. Enquiry awal tidak menjamin kelulusan. Kelayakan dan kelulusan tertakluk kepada semakan.',
        },
        {
          question: 'Maklumat apa yang diperlukan untuk bermula?',
          answer:
            'Biasanya maklumat asas seperti nama bisnes, jenis bisnes, lokasi, dan saluran bisnes anda.',
        },
        {
          question: 'Adakah saya perlu bayar apa-apa untuk buat enquiry?',
          answer: 'Tidak ada bayaran untuk semakan awal melalui enquiry.',
        },
        {
          question: 'Adakah saya perlukan hardware khas atau integration?',
          answer:
            'Tidak semestinya. Untuk kedai fizikal, Atome menggunakan aliran pembayaran berasaskan QR. Untuk kedai online, integration bergantung kepada platform dan saluran jualan anda.',
        },
        {
          question: 'Bolehkah bisnes saya dipaparkan dalam app Atome?',
          answer:
            'Ya. Atome mempunyai keupayaan untuk memaparkan merchant dalam app, tertakluk kepada proses dan keperluan mereka.',
        },
        {
          question: 'Adakah setiap pelanggan akan mendapat limit yang sama?',
          answer:
            'Tidak. Kelayakan dan limit pelanggan boleh berbeza mengikut profil pengguna, jenis pembayaran, dan penilaian Atome.',
        },
        {
          question: 'Bagaimana yuran merchant ditentukan?',
          answer:
            'Tiada setup fee. Struktur merchant adalah berdasarkan MDR per transaksi, dan terma komersial akan dijelaskan semasa proses onboarding.',
        },
      ],
      supportLine:
        'Perlu bantuan tentang yuran, onboarding, kesesuaian bisnes, atau kedai online? WhatsApp kami untuk semakan awal.',
      moreTitle: 'Lebih banyak soalan merchant',
      moreGroups: [
        {
          title: 'Yuran & terma komersial',
          items: [
            {
              question: 'Apa yang membezakan Atome dengan pilihan pay-later lain?',
              answer:
                'Atome bukan sekadar satu lagi pilihan bayaran di checkout. Merchant juga berpeluang dipaparkan dalam app Atome, disokong dengan kempen atau voucher tertentu, dan lebih mudah diakses oleh pengguna debit card yang mungkin tidak menggunakan credit card.',
            },
            {
              question: 'Bagaimana jika pelanggan tidak bayar semula kepada Atome?',
              answer:
                'Pengurusan bayaran balik pelanggan adalah di bawah proses Atome. Merchant akan dijelaskan tentang aliran settlement dan terma berkaitan semasa onboarding.',
            },
            {
              question: 'Berapa ramai orang menggunakan Atome?',
              answer:
                'Atome mempunyai pangkalan pengguna yang besar di Malaysia dan rantau ini. Selain fungsi checkout, merchant juga berpeluang mendapat visibility dalam app Atome.',
            },
            {
              question: 'Berapa yuran Atome?',
              answer:
                'Untuk merchant yang kami uruskan, struktur yang biasa kami jelaskan ialah 6% + RM1 bagi setiap transaksi. Tiada setup fee dan tiada monthly fee. Pengesahan akhir masih tertakluk kepada terma onboarding semasa.',
            },
            {
              question: 'Bolehkah merchant dapat kadar lebih rendah daripada 6%?',
              answer:
                'Ya, dalam sesetengah keadaan. Merchant dengan GMV tinggi, banyak cawangan, atau profil jenama yang kuat mungkin boleh dirundingkan kadar yang lebih baik dengan Atome.',
            },
            {
              question: 'Adakah setiap pelanggan mempunyai credit limit yang sama?',
              answer:
                'Tidak. Limit pelanggan berbeza mengikut profil pengguna, jenis pembayaran, dan aktiviti pembayaran mereka. Jangan nyatakan jumlah tetap pada halaman ini.',
            },
          ],
        },
        {
          title: 'Setup & onboarding',
          items: [
            {
              question: 'Adakah onboarding susah?',
              answer:
                'Tidak rumit jika maklumat asas dan dokumen disediakan dengan betul. Kami bantu merchant faham langkah awal dan proses seterusnya.',
            },
            {
              question: 'Adakah saya perlu signboard yang proper?',
              answer:
                'Ya. Atome biasanya memerlukan signboard kedai yang proper, bukan sekadar banner. Jika merchant nampak established tetapi belum memenuhi syarat ini, kami boleh bantu semak dahulu.',
            },
            {
              question: 'Adakah saya perlu cashier counter?',
              answer: 'Ya. Atome biasanya memerlukan setup cashier counter untuk kedai fizikal.',
            },
            {
              question: 'Berapa lama assessment biasanya ambil masa?',
              answer:
                'Biasanya sehingga 2 minggu sebelum kontrak sedia untuk ditandatangani, bergantung kepada dokumen dan proses semakan.',
            },
          ],
        },
        {
          title: 'Kesesuaian bisnes',
          items: [
            {
              question: 'Kenapa bukan biar pelanggan guna installment credit card sahaja?',
              answer:
                'Ramai pelanggan tidak mempunyai credit card, terutamanya golongan yang lebih muda. Atome memberi satu lagi pilihan bayaran ansuran melalui app, jadi bisnes anda tidak hanya bergantung kepada pengguna credit card.',
            },
            {
              question: 'Boleh mohon kalau bisnes saya di luar Malaysia?',
              answer: 'Tidak. Atome Malaysia hanya menerima bisnes yang berdaftar di Malaysia.',
            },
            {
              question: 'Bagaimana jika saya menjalankan kedai online?',
              answer:
                'Boleh, tetapi laman anda perlu mempunyai checkout page yang proper. Dalam sesetengah kes, Atome mungkin meminta screenshot atau live demo semasa assessment.',
            },
            {
              question: 'Adakah Atome akan minta product list?',
              answer:
                'Kadang-kadang ya, terutamanya semasa assessment. Merchant sepatutnya bersedia untuk menyediakan SKU atau product list jika diminta.',
            },
            {
              question: 'Bagaimana jika bisnes saya dalam kategori berisiko tinggi?',
              answer:
                'Ia mungkin memerlukan semakan yang lebih teliti. Atome mungkin meminta dokumen tambahan atau kelulusan tambahan bergantung kepada kategori bisnes.',
            },
          ],
        },
      ],
      supportNote:
        'Untuk maklumat lanjut, rujuk deck Atome dalam folder getting started atau WhatsApp kami untuk semakan awal.',
    },
    note: {
      title: 'Nota penting',
      body: 'Novalink menyokong koordinasi enquiry merchant dan panduan onboarding. Novalink bukan sebahagian daripada pasukan dalaman Atome. Kelayakan dan kelulusan tertakluk kepada semakan serta keperluan pihak berkaitan.',
      linkLabel: 'Ketahui lebih lanjut di laman rasmi Atome Malaysia',
      linkHref: 'https://www.atome.my/en-my/business',
    },
    finalCta: {
      title: 'Bersedia untuk semak langkah seterusnya?',
      body: 'WhatsApp kami dengan nama bisnes, jenis bisnes, dan lokasi anda untuk semakan awal.',
      primaryCta: 'Buat enquiry merchant',
      secondaryCta: 'WhatsApp untuk maklumat lanjut',
    },
  },
  en: {
    metaTitle: 'Atome Merchant Enquiry',
    metaDescription:
      'Atome merchant enquiry page for first-step guidance, an initial check, and onboarding support by Novalink.',
    hero: {
      headline: 'Want to offer Atome to your customers?',
      subheadline:
        'Help your business add another payment option at checkout with clearer enquiry and onboarding guidance.',
      supportLine:
        'Atome is a Buy Now Pay Later (BNPL) / instalment payment option that gives customers more flexibility at the point of purchase.',
      primaryCta: 'Start merchant enquiry',
      secondaryText: 'WhatsApp for more information',
    },
    explainer: {
      title: 'What is Atome Buy Now Pay Later?',
      bullets: [
