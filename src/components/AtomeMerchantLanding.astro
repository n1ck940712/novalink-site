      supportNote:
        'For more information, refer to the Atome deck in the getting started folder or WhatsApp us for an initial check.',
    },
    note: {
      title: 'Important note',
      body: 'Novalink supports merchant enquiry coordination and onboarding guidance. Novalink is not part of Atome’s internal team. Eligibility and approval remain subject to review and relevant requirements.',
      linkLabel: 'Learn more on the official Atome Malaysia website',
      linkHref: 'https://www.atome.my/en-my/business',
    },
    finalCta: {
      title: 'Ready to check the next step?',
      body: 'WhatsApp us with your business name, business type, and location for an initial check.',
