---
import type { FAQItem } from '../content/site-data';

interface Props {
  heading?: string;
  intro?: string;
  items: FAQItem[];
}

const {
  heading = 'Frequently Asked Questions',
  intro = 'Answers to common questions from teams evaluating Novalink support.',
  items,
} = Astro.props;
---

<section class="container-shell pt-12" id="faq">
  <div class="space-y-4">
    <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">{heading}</h2>
    <p class="max-w-3xl text-base text-slate-600">{intro}</p>
  </div>

  <div class="mt-7 space-y-3">
    {items.map((item) => (
      <details class="panel group px-5 py-4">
        <summary class="cursor-pointer list-none text-sm font-semibold text-slate-900 marker:content-none">
          <span class="inline-flex items-center justify-between gap-4">
            <span>{item.question}</span>
            <span class="text-brand-700 transition group-open:rotate-45">+</span>
          </span>
        </summary>
        <p class="pt-3 text-sm leading-relaxed text-slate-600">{item.answer}</p>
      </details>
    ))}
  </div>
</section>
