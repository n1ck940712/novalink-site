---
import type { ProofMetric } from '../content/site-data';

interface Props {
  heading?: string;
  intro?: string;
  metrics: ProofMetric[];
}

const {
  heading = 'Proof & Delivery Confidence',
  intro = 'Use this area to add concrete client logos, KPIs, and mini case studies as they become available.',
  metrics,
} = Astro.props;
---

<section class="container-shell pt-12" id="proof-section">
  <div class="space-y-4">
    <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">{heading}</h2>
    <p class="max-w-3xl text-base text-slate-600">{intro}</p>
  </div>

  <div class="mt-8 grid gap-5 md:grid-cols-3">
    {metrics.map((metric) => (
      <article class="panel p-6">
        <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">{metric.label}</p>
        <p class="mt-3 text-lg font-semibold text-slate-900">{metric.value}</p>
      </article>
    ))}
  </div>

  <div class="mt-8 panel border-dashed p-6">
    <p class="text-sm font-medium text-slate-700">Case study placeholders</p>
    <p class="mt-2 text-sm text-slate-600">
      Add 2 to 3 concise stories here: challenge, action, and measurable outcome. Keep each card under 120 words for scanability.
    </p>
  </div>
</section>
