---
import type { ProofMetric } from '../content/site-data';

interface Props {
  heading?: string;
  intro?: string;
  metrics: ProofMetric[];
}

const {
  heading = 'Proof & Delivery Confidence',
  intro = 'A quick overview of how Novalink supports execution and collaboration.',
  metrics,
} = Astro.props;
---

<section class="container-shell pt-12" id="proof-section">
  <div class="space-y-4">
    <h2 class="text-2xl font-semibold text-slate-900 sm:text-3xl">{heading}</h2>
    <p class="max-w-3xl text-base text-slate-600">{intro}</p>
  </div>

  <div class="mt-8 grid gap-5 md:grid-cols-3">
    {metrics.map((metric) => (
      <article class="panel p-6">
        <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">{metric.label}</p>
        <p class="mt-3 text-lg font-semibold text-slate-900">{metric.value}</p>
      </article>
    ))}
  </div>
</section>
